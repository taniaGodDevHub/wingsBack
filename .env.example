# Скопируйте в .env (файл в .gitignore) и заполните значения.
# На prod: те же переменные в окружении сервера / PHP-FPM / systemd / CI secrets.

# DaData — https://dadata.ru/profile/
# API-ключ: подсказки адресов (suggest)
DADATA_API_KEY=
# Секретный ключ: стандартизация адресов (clean), если понадобится позже
DADATA_SECRET_KEY=

# Почта Timeweb (SMTP)
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_SCHEME=smtps
SMTP_USER=info@e-wings.ru
SMTP_PASSWORD=
SMTP_FROM_NAME=Wings
# 1 — письма в runtime/mail (для разработки без SMTP), 0 — реальная отправка
MAIL_USE_FILE_TRANSPORT=0

# URL фронтенда (ссылки в письмах рассылки новостей)
FRONTEND_BASE_URL=https://e-wings.ru

# СДЭК API v2 — https://www.cdek.ru/ru/integration/api
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
